APP_ENV=production
APP_DEBUG=false

DB_HOST=your_db_host
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=your_db_name

# مفتاح سري مؤقت لإنشاء أول حساب أدمن فقط
ADMIN_SETUP_KEY=change_this_to_a_long_random_secret

# ── إشعارات Push (تصل حتى لو الموقع مقفول تمامًا على الهاتف/الكمبيوتر) ──
# ولّدها مرة واحدة بالأمر: php generate_vapid_keys.php
# ولازم الموقع يشتغل على HTTPS عشان الإشعارات دي تشتغل (إلا localhost وقت التجربة)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
